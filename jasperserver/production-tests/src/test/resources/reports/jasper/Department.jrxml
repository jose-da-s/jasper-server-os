	<parameter name="department" class="java.lang.Integer"/>
	<query language="sql"><![CDATA[select *
from employee emp
inner join department dep ON emp.department_id = dep.department_id
where dep.department_id=$P{department} and $X{IN, emp.gender, gender} and $X{IN, marital_status, maritalStatus}]]></query>
