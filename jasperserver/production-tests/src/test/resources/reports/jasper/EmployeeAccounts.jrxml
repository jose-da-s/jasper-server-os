<jasperReport name="EmployeeAccounts" language="java" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="50" bottomMargin="50" uuid="3e58e16a-9663-4152-9622-bd3860165ed6">
	<property name="net.sf.jasperreports.export.pdf.tagged" value="true"/>
	<property name="net.sf.jasperreports.export.pdf.tag.language" value="EN-US"/>
	<style name="Sans_Normal" default="true" fontName="SansSerif" fontSize="12.0" pdfFontName="Helvetica" pdfEncoding="Cp1252" pdfEmbedded="false"/>
	<style name="Sans_Bold" fontName="SansSerif" fontSize="12.0" bold="true" pdfFontName="Helvetica-Bold" pdfEncoding="Cp1252" pdfEmbedded="false"/>
	<style name="Sans_Italic" fontName="SansSerif" fontSize="12.0" italic="true" pdfFontName="Helvetica-Oblique" pdfEncoding="Cp1252" pdfEmbedded="false"/>
	<style name="PageHeader" style="Sans_Bold" forecolor="#FFFFFF"/>
	<style name="detail">
		<conditionalStyle mode="Opaque" backcolor="#E0E0E0">
			<conditionExpression><![CDATA[new Boolean($V{CityGroup_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
		</conditionalStyle>
	</style>
	<parameter name="EmployeeID" class="java.lang.String"/>
	<query language="sql"><![CDATA[SELECT name, phone_office, billing_address_city, billing_address_street, billing_address_country 
		FROM accounts
		WHERE assigned_user_id = $P{EmployeeID} 
		ORDER BY billing_address_country, billing_address_city]]></query>
	<field name="name" class="java.lang.String"/>
	<field name="phone_office" class="java.lang.String"/>
	<field name="billing_address_city" class="java.lang.String"/>
	<field name="billing_address_street" class="java.lang.String"/>
	<field name="billing_address_country" class="java.lang.String"/>
	<variable name="CityyNumber" resetType="Group" calculation="System" resetGroup="CityGroup" class="java.lang.Integer">
		<initialValueExpression><![CDATA[($V{CityyNumber} != null)?(new Integer($V{CityyNumber}.intValue() + 1)):(new Integer(1))]]></initialValueExpression>
	</variable>
	<group name="CityGroup" minHeightToStartNewPage="60">
		<expression><![CDATA[$F{billing_address_city}]]></expression>
		<groupHeader>
			<band height="30" splitType="Stretch">
				<element kind="frame" uuid="4d6d792d-3c71-4b4e-8425-b02170f8db55" mode="Opaque" x="0" y="14" width="515" height="16" backcolor="#C0C0C0">
					<property name="net.sf.jasperreports.export.pdf.tag.tr" value="full"/>
					<property name="net.sf.jasperreports.export.pdf.tag.td" value="full"/>
					<property name="net.sf.jasperreports.export.pdf.tag.colspan" value="4"/>
					<element kind="textField" uuid="36116028-ff06-482e-83a2-9f12790c27fd" x="0" y="0" width="515" height="16" textAdjust="StretchHeight" hTextAlign="Left" style="Sans_Bold">
						<expression><![CDATA["  " + String.valueOf($V{CityyNumber}) + ". " + $F{billing_address_city}+ ", " + $F{billing_address_country}]]></expression>
					</element>
					<box>
						<bottomPen lineWidth="1.0" lineStyle="Solid"/>
					</box>
				</element>
			</band>
		</groupHeader>
	</group>
	<title height="50" splitType="Stretch">
		<element kind="line" uuid="d944bd21-4ef3-4e03-b71a-b2679c1198d7" x="0" y="1" width="515" height="1" forecolor="#000000"/>
