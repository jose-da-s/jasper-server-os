<jasperReport name="StandardChartsEyeCandyReport" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" resourceBundle="standardCharts" whenResourceMissingType="Key" uuid="f51de7f9-ae51-45e0-9cad-8048c1b7c06b">
	<property name="net.sf.jasperreports.chart.theme" value="eye.candy.sixties"/>
	<property name="net.sf.jasperreports.export.xls.ignore.graphics" value="false"/>
	<dataset name="categoryDataset" uuid="9a7aebb0-0fa7-4c9a-ba07-f48d641aee0f">
		<query language="sql"><![CDATA[SELECT * FROM sales_fact 
    INNER JOIN sales_person ON sales_person.id = sales_fact.sales_person_id
    INNER JOIN sales_state ON sales_state.id = sales_fact.sales_state_id 
    WHERE sales_state.id > 1 AND sales_state.id < 8
    ORDER BY full_name, sales_state]]></query>
		<field name="full_name" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<field name="amount" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="sales_state" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<variable name="personAmount" resetType="Group" calculation="Sum" resetGroup="salesState" class="java.lang.Integer">
			<expression><![CDATA[$F{amount}]]></expression>
		</variable>
		<group name="person">
			<expression><![CDATA[$F{full_name}]]></expression>
		</group>
		<group name="salesState">
			<expression><![CDATA[$F{sales_state}]]></expression>
		</group>
	</dataset>
	<dataset name="pieDataset" uuid="6f64361f-9971-4958-90d2-926fe6ef3a0a">
		<query language="sql"><![CDATA[SELECT * FROM sales_fact 
    INNER JOIN sales_state ON sales_state.id = sales_fact.sales_state_id 
    WHERE sales_state.id > 1 AND sales_state.id < 8
    ORDER BY sales_state]]></query>
		<field name="amount" class="java.lang.Integer">
			<description><![CDATA[]]></description>
