		<group name="salesState">
			<expression><![CDATA[$F{sales_state}]]></expression>
		</group>
	</dataset>
	<dataset name="xyDataset" uuid="74e49878-197b-4604-9364-249ac90ae841">
		<query language="sql"><![CDATA[SELECT * FROM sales_fact 
    INNER JOIN sales_state ON sales_state.id = sales_fact.sales_state_id 
    WHERE sales_state.id > 1 AND sales_state.id < 8
    ORDER BY sales_state, probability, amount]]></query>
		<field name="amount" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="probability" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="sales_state" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<group name="salesState">
			<expression><![CDATA[$F{sales_state}]]></expression>
		</group>
		<group name="probability">
			<expression><![CDATA[$F{probability}]]></expression>
		</group>
		<group name="amount">
			<expression><![CDATA[$F{amount}]]></expression>
		</group>
	</dataset>
	<dataset name="timeSeriesDataset" uuid="09ddb1ab-7196-4ca5-98ec-c66e7adec295">
		<query language="sql"><![CDATA[SELECT * FROM opportunities
	INNER JOIN users ON opportunities.assigned_user_id = users.id
	WHERE sales_stage LIKE 'Closed%'
	ORDER BY sales_stage, date_closed]]></query>
		<field name="amount" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="date_closed" class="java.util.Date">
			<description><![CDATA[]]></description>
		</field>
		<field name="sales_stage" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<variable name="monthAmount" resetType="Group" calculation="Sum" resetGroup="month" class="java.lang.Integer">
			<expression><![CDATA[$F{amount}]]></expression>
		</variable>
		<group name="stage">
			<expression><![CDATA[$F{sales_stage}]]></expression>
		</group>
		<group name="month">
			<expression><![CDATA[new Integer($F{date_closed}.getMonth())]]></expression>
		</group>
	</dataset>
	<dataset name="timePeriodDataset" uuid="8ceed8eb-547f-4fb9-be66-06578f6b9a50">
		<query language="sql"><![CDATA[SELECT * FROM sales_fact 
    INNER JOIN sales_state ON sales_state.id = sales_fact.sales_state_id 
    INNER JOIN sales_date_of_start ON sales_date_of_start.id = sales_fact.sales_date_of_start_id
    INNER JOIN sales_date_of_close ON sales_date_of_close.id = sales_fact.sales_date_of_close_id
    INNER JOIN sales_person ON sales_person.id = sales_fact.sales_person_id
    WHERE sales_state.id > 1 AND sales_state.id < 8 AND full_name LIKE '%sally%']]></query>
		<field name="amount" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="start_year" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="start_month" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="close_year" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="close_month" class="java.lang.Integer">
			<description><![CDATA[]]></description>
		</field>
		<field name="sales_state" class="java.lang.String">
			<description><![CDATA[]]></description>
		</field>
		<variable name="startDate" class="java.util.Date">
			<expression><![CDATA[new Date($F{start_year}.intValue() - 1900, $F{start_month}.intValue(), 1)]]></expression>
		</variable>
		<variable name="closeDate" class="java.util.Date">
			<expression><![CDATA[new Date($F{close_year}.intValue() - 1900, $F{close_month}.intValue(), 1)]]></expression>
		</variable>
	</dataset>
