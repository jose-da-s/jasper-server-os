<!-- Created with Jaspersoft Studio version 7.0.0.final using JasperReports Library version 7.0.0-b478feaa9aab4375eba71de77b4ca138ad2f62aa  -->
<jasperReport name="SalesByMonthDetail" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="515" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" scriptletClass="test.TestScriptlet" resourceBundle="sales" whenResourceMissingType="Error" uuid="a0b6360e-c52b-4acb-925e-6e7c8aa327ab">
	<style name="Sans_Normal" default="true" fontName="SansSerif" fontSize="12.0" pdfFontName="Helvetica" pdfEncoding="Cp1252" pdfEmbedded="false"/>
	<style name="Sans_Bold" fontName="SansSerif" fontSize="12.0" bold="true" pdfFontName="Helvetica-Bold" pdfEncoding="Cp1252" pdfEmbedded="false"/>
	<style name="Sans_Italic" fontName="SansSerif" fontSize="12.0" italic="true" pdfFontName="Helvetica-Oblique" pdfEncoding="Cp1252" pdfEmbedded="false"/>
	<style name="PageHeader" style="Sans_Normal" forecolor="#FFFFFF"/>
	<style name="detail">
		<conditionalStyle mode="Opaque" backcolor="#E0E0E0">
			<conditionExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></conditionExpression>
		</conditionalStyle>
	</style>
	<parameter name="CloseYear" class="java.lang.Short"/>
	<parameter name="CloseMonth" class="java.lang.Short"/>
	<query language="sql"><![CDATA[SELECT
			sales_fact.amount as amount,
			sales_date_of_close.close_month_name as close_month_name,
			sales_person.first_name as sales_person_first_name,
			sales_person.last_name as sales_person_last_name,
			sales_account.account_name as account_name
		FROM
		    sales_fact
		    INNER JOIN sales_date_of_close ON sales_fact.sales_date_of_close_id = sales_date_of_close.id
		    INNER JOIN sales_person ON sales_fact.sales_person_id = sales_person.id
		    INNER JOIN sales_account ON sales_fact.sales_account_id = sales_account.id
		WHERE
			sales_date_of_close.close_year = $P{CloseYear} and
			sales_date_of_close.close_month = $P{CloseMonth}
		ORDER BY sales_person.id, sales_account.id]]></query>
	<field name="amount" class="java.lang.Float"/>
	<field name="sales_person_first_name" class="java.lang.String"/>
	<field name="sales_person_last_name" class="java.lang.String"/>
	<field name="account_name" class="java.lang.String"/>
	<variable name="totalAmount" calculation="Sum" class="java.lang.Float">
		<expression><![CDATA[$F{amount}]]></expression>
		<initialValueExpression><![CDATA[new Float(0.f)]]></initialValueExpression>
	</variable>
	<pageHeader height="16" splitType="Stretch">
		<element kind="frame" uuid="222c00b8-fa9b-4a82-8ede-b9350eb91dd5" mode="Opaque" x="0" y="0" width="515" height="16" backcolor="#C0C0C0">
			<property name="net.sf.jasperreports.export.pdf.tag.table" value="start"/>
			<property name="net.sf.jasperreports.export.pdf.tag.tr" value="full"/>
			<element kind="textField" uuid="413a355e-34e8-4e5a-b4bc-16f8cffabdba" x="10" y="0" width="120" height="16" textAdjust="StretchHeight" style="PageHeader">
				<expression><![CDATA[$R{sales.person}]]></expression>
				<property name="net.sf.jasperreports.export.pdf.tag.th" value="full"/>
			</element>
			<element kind="textField" uuid="fa2b13c4-54b7-4d13-916f-bd490944ae8f" x="140" y="0" width="260" height="16" textAdjust="StretchHeight" style="PageHeader">
				<expression><![CDATA[$R{sales.account}]]></expression>
				<property name="net.sf.jasperreports.export.pdf.tag.th" value="full"/>
			</element>
			<element kind="textField" uuid="080094ce-5700-4f2c-8196-d4f96d8fe3a9" x="410" y="0" width="95" height="16" textAdjust="StretchHeight" hTextAlign="Right" style="PageHeader">
				<expression><![CDATA[$R{sales.amount}]]></expression>
				<property name="net.sf.jasperreports.export.pdf.tag.th" value="full"/>
			</element>
		</element>
	</pageHeader>
	<detail>
		<band height="20" splitType="Prevent">
			<element kind="frame" uuid="7b8a28bb-7bce-418c-b6bc-adedc1870e4b" x="0" y="0" width="515" height="20" style="detail">
				<property name="net.sf.jasperreports.export.pdf.tag.tr" value="full"/>
				<element kind="textField" uuid="3721e5a7-3509-4b5e-9407-10284201c42e" x="10" y="4" width="120" height="16" textAdjust="StretchHeight" printRepeatedValues="false" printInFirstWholeBand="true">
					<expression><![CDATA[$F{sales_person_first_name} + " " + $F{sales_person_last_name}]]></expression>
					<property name="net.sf.jasperreports.export.pdf.tag.td" value="full"/>
				</element>
				<element kind="textField" uuid="0a1780e8-fdd3-4173-8fdc-d5ca2338019c" x="140" y="4" width="260" height="16" textAdjust="StretchHeight">
					<expression><![CDATA[$F{account_name}]]></expression>
					<property name="net.sf.jasperreports.export.pdf.tag.td" value="full"/>
				</element>
				<element kind="textField" uuid="be833463-5ec4-49c8-a3c3-6d38ec127c65" x="410" y="4" width="95" height="16" textAdjust="StretchHeight" pattern="#0.00" hTextAlign="Right">
					<expression><![CDATA[$F{amount}]]></expression>
					<property name="net.sf.jasperreports.export.pdf.tag.td" value="full"/>
				</element>
				<box style="detail">
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#808080"/>
				</box>
			</element>
		</band>
	</detail>
	<pageFooter splitType="Stretch">
		<element kind="frame" uuid="39dc0629-cad1-4505-81a4-1cc2ac7ac72b" mode="Transparent" x="0" y="0" width="0" height="0">
			<property name="net.sf.jasperreports.export.pdf.tag.table" value="end"/>
		</element>
	</pageFooter>
</jasperReport>
